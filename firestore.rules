rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }
    function isValidTask(data) {
      return data.keys().hasAll(['uid', 'title', 'status']) &&
             data.uid == request.auth.uid &&
             data.status in ['todo', 'doing', 'done'] &&
             (!('dueDate' in data) || data.dueDate is string || data.dueDate == null) &&
             (!('reminded' in data) || data.reminded is bool);
    }
    function isValidSpending(data) {
      return data.keys().hasAll(['uid', 'amount', 'type', 'scope', 'category', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.amount is number &&
             data.type in ['expense', 'income'] &&
             data.scope in ['personal', 'work'];
    }
    function isValidSkill(data) {
      return data.keys().hasAll(['uid', 'name', 'progress']) &&
             data.uid == request.auth.uid &&
             data.progress is number;
    }
    function isValidJournal(data) {
      return data.keys().hasAll(['uid', 'content', 'createdAt']) &&
             data.uid == request.auth.uid &&
             (!('title' in data) || data.title is string) &&
             (!('tags' in data) || data.tags is list);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isDocOwner() && isValidTask(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /skills/{skillId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSkill(request.resource.data);
      allow update: if isDocOwner() && isValidSkill(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /spending/{spendingId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSpending(request.resource.data);
      allow update: if isDocOwner() && isValidSpending(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /journal/{journalId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidJournal(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
